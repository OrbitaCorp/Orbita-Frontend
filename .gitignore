# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...pero sí versionar los templates de ejemplo (no tienen secretos)
!.env.example
!**/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# apps/* (repo restructured into apps/web + apps/api, not a workspace tool yet;
# patterns above are anchored to repo root and don't reach into apps/*)
apps/*/node_modules
apps/*/.next/
apps/*/out/
apps/*/build
apps/*/coverage
apps/*/.env*.local
