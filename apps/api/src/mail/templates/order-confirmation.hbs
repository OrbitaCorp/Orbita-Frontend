<!DOCTYPE html>
<html>
<body style="font-family: sans-serif; padding: 20px;">
  <h2>Pedido #{{orderNumber}} confirmado</h2>
  <p>Gracias por tu compra en <strong>{{storeName}}</strong>. Confirmamos tu pedido #{{orderNumber}}.</p>
  <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
    <thead>
      <tr>
        <th style="text-align: left; border-bottom: 1px solid #ddd; padding: 8px;">Producto</th>
        <th style="text-align: center; border-bottom: 1px solid #ddd; padding: 8px;">Cant.</th>
        <th style="text-align: right; border-bottom: 1px solid #ddd; padding: 8px;">Precio</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td style="padding: 8px; border-bottom: 1px solid #eee;">{{this.name}}</td>
        <td style="padding: 8px; text-align: center; border-bottom: 1px solid #eee;">{{this.quantity}}</td>
        <td style="padding: 8px; text-align: right; border-bottom: 1px solid #eee;">{{this.price}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  <p style="font-size: 16px;"><strong>Total: {{total}}</strong></p>
</body>
</html>
