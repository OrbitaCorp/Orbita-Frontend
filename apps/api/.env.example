# Conexión pooled (Transaction mode, puerto 6543) — la usa la app en runtime.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"

# Conexión directa (Session mode, puerto 5432) — la usa Prisma Migrate.
# pgbouncer no soporta algunas operaciones que las migraciones necesitan.
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Supabase Auth — obtener en Settings > API del proyecto
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # service_role (SECRETO — nunca exponer al cliente)

# Frontend URL (para el link de reset-password en emails de recuperación, y
# el redirect final del flujo de Google OAuth)
FRONTEND_URL="http://localhost:3001"

# Auth propio (JWT HS256)
JWT_SECRET="generar con: openssl rand -hex 32"
JWT_EXPIRES_IN=15m

# Google OAuth (RBT-287) — OAuth Client ID tipo "Web application", creado en
# Google Cloud Console > APIs & Services > Credentials. El Authorized redirect
# URI configurado ahí debe ser IDÉNTICO a GOOGLE_REDIRECT_URI.
GOOGLE_CLIENT_ID="000000000000-xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/v1/auth/google/callback"

# Servidor
PORT=3000

# ── MercadoPago — suscripción del negocio a Órbita ────────────────────────────
# OJO: esto es el cobro NEGOCIO → ÓRBITA (débito automático del plan), distinto
# de los pagos CLIENTE → NEGOCIO que maneja el módulo mercadopago/.
#
# El Access Token tiene que ser de una aplicación de MP con el producto
# "Suscripciones" habilitado — una app configurada como "Checkout API vía
# Orders" no puede crear preapprovals.
MP_ACCESS_TOKEN=

# Plan cobrado. Producción: 5000 ARS cada 3 meses.
# Para probar el cobro recurrente sin esperar meses: AMOUNT=1, FREQUENCY=3,
# FREQUENCY_TYPE=days (un peso cada 3 días).
MP_SUBSCRIPTION_AMOUNT=5000
MP_SUBSCRIPTION_FREQUENCY=3
MP_SUBSCRIPTION_FREQUENCY_TYPE=months   # "days" | "months"
MP_SUBSCRIPTION_CURRENCY=ARS

# Mail (dejar vacío en desarrollo — el servicio loguea en consola en vez de mandar)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Orbita" <noreply@orbita.site>
